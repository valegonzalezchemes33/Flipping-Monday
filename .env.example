# ============================================================================
# .env.example — copia este archivo a .env y completa tus API keys
# ============================================================================

# Base de datos SQLite (ruta dentro del contenedor Docker)
DATABASE_URL=file:/app/data/custom.db

# === IA — Chat del Sidekick ===
# El SDK Z.ai (z-ai-web-dev-sdk) ya viene preconfigurado en el código.
# NO necesitas ninguna key para que funcione (usa el SDK interno).

# Opcional: Groq API key para chat más rápido y sin rate limits
# Consigue una gratis en: https://console.groq.com/keys
GROQ_API_KEY=

# === Monday.com (opcional) ===
# Si quieres importar boards de tu Monday.com real
# Consigue tu API token en: https://monday.com/developers/v2#authentication-section
MONDAY_API_KEY=

# === Configuración de la app ===
NODE_ENV=production
PORT=3000
