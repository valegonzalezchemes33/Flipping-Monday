# ============================================================================
# .env.example — copia este archivo a .env y completa tus API keys
# ============================================================================

# === Base de datos PostgreSQL ===
# Proveedores recomendados:
#   - Neon (gratis): https://neon.tech
#   - Vercel Postgres: https://vercel.com/docs/storage
#   - Supabase: https://supabase.com
# Ejemplo de URL (reemplaza user, password, host y db):
DATABASE_URL="postgresql://user:password@host:5432/monday_ai?schema=public"

# === IA — Chat del Sidekick ===
# El SDK Z.ai (z-ai-web-dev-sdk) ya viene preconfigurado en el código.
# NO necesitas ninguna key para que funcione (usa el SDK interno).

# Opcional: NVIDIA Integrate API key para chat más rápido y sin rate limits
# Consigue una gratis en: https://build.nvidia.com/
GROQ_API_KEY=

# === Monday.com (opcional) ===
# Si quieres importar boards de tu Monday.com real
# Consigue tu API token en: https://monday.com/developers/v2#authentication-section
MONDAY_API_KEY=

# === Configuración de la app ===
NODE_ENV=production
PORT=3000
