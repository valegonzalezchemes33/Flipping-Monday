// =============================================================================
// Prisma Schema -- monday-AI CRM
// =============================================================================
// Refleja el dominio de la aplicacion:
// boards, grupos, items, columnas, agentes IA, ejecuciones, automatizaciones.
// Base de datos: PostgreSQL (default en desarrollo y produccion).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Organizacion y Usuarios
// =============================================================================

model Organization {
  id       String  @id @default(cuid())
  name     String
  planTier String  @default("free")
  logoUrl  String?

  users      User[]
  workspaces Workspace[]
  agents     Agent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id             String  @id @default(cuid())
  email          String  @unique
  name           String
  role           String  @default("member")
  color          String  @default("#0072E5")
  avatarUrl      String?
  organizationId String

  organization  Organization     @relation(fields: [organizationId], references: [id])
  updates       Update[]
  notifications Notification[]
  agentsCreated Agent[]          @relation("AgentCreator")
  executions    AgentExecution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

// =============================================================================
// Workspace y Boards
// =============================================================================

model Workspace {
  id             String @id @default(cuid())
  name           String
  organizationId String
  icon           String @default("briefcase")

  organization Organization @relation(fields: [organizationId], references: [id])
  boards       Board[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model Board {
  id          String  @id @default(cuid())
  name        String
  description String?
  workspaceId String
  icon        String  @default("table")
  color       String  @default("#0072E5")
  isArchived  Boolean @default(false)

  workspace Workspace   @relation(fields: [workspaceId], references: [id])
  groups    Group[]
  columns   ColumnDef[]
  agents    Agent[]
  views     BoardView[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
}

model BoardView {
  id      String @id @default(cuid())
  boardId String
  name    String
  type    String

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId])
}

model Group {
  id        String  @id @default(cuid())
  boardId   String
  title     String
  color     String  @default("#579BFC")
  position  Int     @default(0)
  collapsed Boolean @default(false)

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  items Item[]

  @@index([boardId])
}

// =============================================================================
// Columnas e Items
// =============================================================================

model ColumnDef {
  id       String  @id @default(cuid())
  boardId  String
  title    String
  type     String
  width    Int?
  position Int     @default(0)
  options  String?

  board  Board         @relation(fields: [boardId], references: [id], onDelete: Cascade)
  values ColumnValue[]

  @@index([boardId])
}

model Item {
  id         String  @id @default(cuid())
  boardId    String
  groupId    String
  name       String
  position   Int     @default(0)
  isArchived Boolean @default(false)

  group      Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  values     ColumnValue[]
  updates    Update[]
  executions AgentExecution[]
  files      AppFile[]
  subitems   Subitem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId])
  @@index([boardId])
}

model Subitem {
  id       String  @id @default(cuid())
  parentId String
  name     String
  done     Boolean @default(false)

  parent Item @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId])
}

model ColumnValue {
  id       String @id @default(cuid())
  itemId   String
  columnId String
  value    String

  item   Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  column ColumnDef @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@unique([itemId, columnId])
  @@index([itemId])
}

// =============================================================================
// Agentes IA y Ejecuciones
// =============================================================================

model Agent {
  id             String  @id @default(cuid())
  name           String
  description    String
  systemPrompt   String
  model          String  @default("glm-4.6")
  temperature    Float   @default(0.4)
  maxTokens      Int     @default(1500)
  icon           String  @default("robot")
  color          String  @default("#0072E5")
  isActive       Boolean @default(true)
  scope          String  @default("board")
  triggers       String  @default("manual")
  schedule       String?
  organizationId String
  createdById    String
  boardId        String?

  organization Organization     @relation(fields: [organizationId], references: [id])
  createdBy    User             @relation("AgentCreator", fields: [createdById], references: [id])
  board        Board?           @relation(fields: [boardId], references: [id])
  executions   AgentExecution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([boardId])
}

model AgentExecution {
  id         String  @id @default(cuid())
  agentId    String
  itemId     String?
  userId     String?
  status     String
  output     String?
  error      String?
  tokensUsed Int?
  durationMs Int?
  model      String?
  backend    String?

  agent Agent @relation(fields: [agentId], references: [id])
  item  Item? @relation(fields: [itemId], references: [id])
  user  User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId])
  @@index([itemId])
}

// =============================================================================
// Automatizaciones y Planes
// =============================================================================

model AutomationRecipe {
  id          String    @id @default(cuid())
  boardId     String
  name        String
  description String
  trigger     String
  action      String
  isActive    Boolean   @default(true)
  runCount    Int       @default(0)
  lastRunAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boardId])
}

model OrchestratorPlan {
  id          String @id @default(cuid())
  boardId     String
  goal        String
  status      String @default("pending")
  steps       String
  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boardId])
}

// =============================================================================
// Updates, Notificaciones y Archivos
// =============================================================================

model Update {
  id               String  @id @default(cuid())
  itemId           String
  authorId         String
  body             String
  mentionedUserIds String?

  item   Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())

  @@index([itemId])
}

model Notification {
  id     String  @id @default(cuid())
  userId String
  type   String
  title  String
  body   String
  itemId String?
  read   Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
}

model AppFile {
  id       String @id @default(cuid())
  itemId   String
  name     String
  url      String
  size     Int
  mimeType String

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([itemId])
}
